			SWITCH(FirstDigit,
			    "1", "Managers",
			    "2", "Specialists (Academic)",
			    "3", "Associate Professionals (Tech/Health)",
			    "4", "Administrative/Clerical",
			    "5", "Service/Sales/Care",
			    "6", "Agriculture/Forestry",
			    "7", "Building/Manufacturing",
			    "8", "Machine Operators",
			    "9", "Elementary Occupations",
			    "0", "Military",
			    "Other"
